{
  "$schema": "https://json.schemastore.org/prettierrc",
  "printWidth": 100,
  "semi": false,
  "singleQuote": true,
  "trailingComma": "es5",
  "arrowParens": "always",
  "bracketSpacing": true,
  "useTabs": false,
  "tabWidth": 2,
  "jsxSingleQuote": true,
  "quoteProps": "consistent",
  "plugins": ["prettier-plugin-tailwindcss"]
}
